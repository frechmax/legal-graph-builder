<https://example.org/eli/de/hh/hbauo/2025/par_72/abs_6/nr_2> eli:description "die Baubeginnanzeige der Bauaufsichtsbehörde vorliegt."@de .

<https://example.org/eli/de/hh/hbauo/2025/par_72/abs_7> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:absatz ;
    eli:number "7" ;
