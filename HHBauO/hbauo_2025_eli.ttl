<https://example.org/eli/de/hh/hbauo/2025/par_73/abs_1/nr_1> eli:description "innerhalb von drei Jahren nach ihrer Erteilung mit der Ausführung des Bauvorhabens nicht begonnen oder"@de .

<https://example.org/eli/de/hh/hbauo/2025/par_73/abs_1/nr_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "2" ;
    eli:is_part_of <https://example.org/eli/de/hh/hbauo/2025/par_73/abs_1> .

