<https://example.org/eli/de/hh/hbauo/2025/par_32/abs_2/nr_2> eli:description "von Gebäuden auf demselben Grundstück mit harter Bedachung einen Abstand von mindestens 15 m,"@de .

<https://example.org/eli/de/hh/hbauo/2025/par_32/abs_2/nr_3> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
