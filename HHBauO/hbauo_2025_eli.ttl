    eli:type_subdivision exvocab:absatz ;
    eli:number "2" ;
    eli:is_part_of <https://example.org/eli/de/hh/hbauo/2025/par_11> .

<https://example.org/eli/de/hh/hbauo/2025/par_11> eli:has_part <https://example.org/eli/de/hh/hbauo/2025/par_11/abs_2> .

<https://example.org/eli/de/hh/hbauo/2025/par_11/abs_3> a eli:LegalResourceSubdivision ;
