<https://example.org/eli/de/hh/hbauo/2025/par_72/abs_6/nr_1> eli:description "die Baugenehmigung der Bauherrin bzw. dem Bauherrn zugegangen ist und"@de .

<https://example.org/eli/de/hh/hbauo/2025/par_72/abs_6/nr_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
