<https://example.org/eli/de/hh/hbauo/2025/par_46a/abs_2> eli:has_part <https://example.org/eli/de/hh/hbauo/2025/par_46a/abs_2/nr_2> .

<https://example.org/eli/de/hh/hbauo/2025/par_46a/abs_2/nr_2> eli:description "Anlagen in explosionsgefährdeten Bereichen,"@de .

<https://example.org/eli/de/hh/hbauo/2025/par_46a/abs_2/nr_3> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "3" ;
