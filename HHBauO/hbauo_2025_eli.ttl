<https://example.org/eli/de/hh/hbauo/2025/par_23/abs_1/nr_1> eli:description "den Technischen Baubestimmungen nach § 85a Absatz 2, der allgemeinen bauaufsichtlichen Zulassung, dem allgemeinen bauaufsichtlichen Prüfzeugnis oder der Zustimmung im Einzelfall entspricht und"@de .

<https://example.org/eli/de/hh/hbauo/2025/par_23/abs_1/nr_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "2" ;
