<https://example.org/eli/de/hh/hbauo/2025/par_49/abs_5/nr_1> eli:description "das Grundstück durch den öffentlichen Personennahverkehr gut erschlossen ist,"@de .

<https://example.org/eli/de/hh/hbauo/2025/par_49/abs_5/nr_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "2" ;
    eli:is_part_of <https://example.org/eli/de/hh/hbauo/2025/par_49/abs_5> .

