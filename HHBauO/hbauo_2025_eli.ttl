<https://example.org/eli/de/hh/hbauo/2025/par_8/abs_1/nr_2> eli:description "biologisch vielfältig zu begrünen oder zu bepflanzen."@de .

<https://example.org/eli/de/hh/hbauo/2025/par_8/abs_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:absatz ;
    eli:number "2" ;
