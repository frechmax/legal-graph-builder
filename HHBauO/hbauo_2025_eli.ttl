<https://example.org/eli/de/hh/hbauo/2025/par_45/abs_3/nr_2> eli:description "Öffnungen vom Gebäudeinnern zum Aufstellraum mit feuerhemmenden, dicht- und selbstschließenden Abschlüssen haben,"@de .

<https://example.org/eli/de/hh/hbauo/2025/par_45/abs_3/nr_3> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "3" ;
