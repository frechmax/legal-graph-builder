<https://example.org/eli/de/hh/hbauo/2025/par_31/abs_4/nr_2> eli:description "innerhalb derselben Nutzungseinheit mit nicht mehr als insgesamt 400 m2 in nicht mehr als zwei Geschossen,"@de .

<https://example.org/eli/de/hh/hbauo/2025/par_31/abs_4/nr_3> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "3" ;
