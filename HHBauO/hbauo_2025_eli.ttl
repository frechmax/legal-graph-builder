<https://example.org/eli/de/hh/hbauo/2025/par_36/abs_1/nr_2> eli:description "in sonstigen Gebäuden der Gebäudeklassen 1 und 2, ausgenommen in Kellergeschossen,"@de .

<https://example.org/eli/de/hh/hbauo/2025/par_36/abs_1/nr_3> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
