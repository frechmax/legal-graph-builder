<https://example.org/eli/de/hh/hbauo/2025/par_30/abs_2/nr_3> eli:description "als innere Brandwand zur Unterteilung landwirtschaftlich genutzter Gebäude in Brandabschnitte von nicht mehr als 10 000 m3 Brutto-Rauminhalt,"@de .

<https://example.org/eli/de/hh/hbauo/2025/par_30/abs_2/nr_4> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
