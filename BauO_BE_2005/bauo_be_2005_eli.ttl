    eli:type_subdivision exvocab:absatz ;
    eli:number "2" ;
    eli:is_part_of <https://example.org/eli/de/be/bauo/2005/par_37> .

<https://example.org/eli/de/be/bauo/2005/par_37> eli:has_part <https://example.org/eli/de/be/bauo/2005/par_37/abs_2> .

<https://example.org/eli/de/be/bauo/2005/par_37/abs_3> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:absatz ;
    eli:number "3" ;
    eli:is_part_of <https://example.org/eli/de/be/bauo/2005/par_37> .

<https://example.org/eli/de/be/bauo/2005/par_37> eli:has_part <https://example.org/eli/de/be/bauo/2005/par_37/abs_3> .

<https://example.org/eli/de/be/bauo/2005/par_37/abs_4> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:absatz ;
