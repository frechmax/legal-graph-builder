<https://example.org/eli/de/be/bauo/2005/par_26/abs_2/nr_4> eli:description "Bauteile aus brennbaren Baustoffen."@de .

<https://example.org/eli/de/be/bauo/2005/par_26/abs_2/nr_1> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "1" ;
    eli:is_part_of <https://example.org/eli/de/be/bauo/2005/par_26/abs_2> .

