<https://example.org/eli/de/be/bauo/2005/par_79/abs_1/nr_1> eli:description "die Ausführung eines Vorhabens entgegen den Vorschriften des § 72 Absatz 1 und 2 begonnen wurde,"@de .

<https://example.org/eli/de/be/bauo/2005/par_79/abs_1/nr_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "2" ;
