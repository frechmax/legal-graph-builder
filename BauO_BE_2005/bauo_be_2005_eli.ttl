<https://example.org/eli/de/be/bauo/2005/par_36/abs_1> eli:has_part <https://example.org/eli/de/be/bauo/2005/par_36/abs_1/nr_3> .

<https://example.org/eli/de/be/bauo/2005/par_36/abs_1/nr_3> eli:description "innerhalb von Nutzungseinheiten mit nicht mehr als 200 Quadratmeter Brutto-Grundfläche und innerhalb von Wohnungen,"@de .

<https://example.org/eli/de/be/bauo/2005/par_36/abs_1/nr_4> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "4" ;
