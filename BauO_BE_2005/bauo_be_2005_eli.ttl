<https://example.org/eli/de/be/bauo/2005/par_61/abs_3/nr_2> eli:description "freistehenden Gebäuden ohne Wohnraum der Gebäudeklassen 1 und 3,"@de .

<https://example.org/eli/de/be/bauo/2005/par_61/abs_3/nr_3> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
