<https://example.org/eli/de/be/bauo/2005/par_36/abs_1/nr_1> eli:description "in Wohngebäuden der Gebäudeklassen 1 und 2,"@de .

<https://example.org/eli/de/be/bauo/2005/par_36/abs_1/nr_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "2" ;
    eli:is_part_of <https://example.org/eli/de/be/bauo/2005/par_36/abs_1> .

<https://example.org/eli/de/be/bauo/2005/par_36/abs_1> eli:has_part <https://example.org/eli/de/be/bauo/2005/par_36/abs_1/nr_2> .

<https://example.org/eli/de/be/bauo/2005/par_36/abs_1/nr_2> eli:description "in sonstigen Gebäuden der Gebäudeklassen 1 und 2, ausgenommen in Kellergeschossen,"@de .

<https://example.org/eli/de/be/bauo/2005/par_36/abs_1/nr_3> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "3" ;
