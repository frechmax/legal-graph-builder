<https://example.org/eli/de/be/bauo/2005/par_48/abs_6/nr_3> eli:description "der notwendige Treppenraum nach § 35 Absatz 8 entraucht werden kann und"@de .

<https://example.org/eli/de/be/bauo/2005/par_48/abs_6/nr_4> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "4" ;
