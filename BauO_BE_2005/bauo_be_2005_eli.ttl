<https://example.org/eli/de/be/bauo/2005/par_31/abs_1/nr_2> eli:description "in Gebäuden der Gebäudeklasse 4 hochfeuerhemmend,"@de .

<https://example.org/eli/de/be/bauo/2005/par_31/abs_1/nr_3> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "3" ;
    eli:is_part_of <https://example.org/eli/de/be/bauo/2005/par_31/abs_1> .

