<https://example.org/eli/de/be/bauo/2005/par_65/abs_2/nr_1> eli:description "die Berufsbezeichnung „Architektin“ oder „Architekt“ führen darf,"@de .

<https://example.org/eli/de/be/bauo/2005/par_65/abs_2/nr_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "2" ;
    eli:is_part_of <https://example.org/eli/de/be/bauo/2005/par_65/abs_2> .

