    eli:type_subdivision exvocab:absatz ;
    eli:number "4" ;
    eli:is_part_of <https://example.org/eli/de/be/bauo/2005/par_29> .

<https://example.org/eli/de/be/bauo/2005/par_29> eli:has_part <https://example.org/eli/de/be/bauo/2005/par_29/abs_4> .

