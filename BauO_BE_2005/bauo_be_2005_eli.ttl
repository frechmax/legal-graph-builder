<https://example.org/eli/de/be/bauo/2005/par_65/abs_1/nr_2> eli:description "geringfügige oder technisch einfache Bauvorhaben."@de .

<https://example.org/eli/de/be/bauo/2005/par_65/abs_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:absatz ;
