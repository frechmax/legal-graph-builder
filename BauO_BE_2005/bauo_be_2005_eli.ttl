<https://example.org/eli/de/be/bauo/2005/par_50/abs_1/nr_1> eli:description "die Wohnung stufen- und schwellenlos erreichbar ist,"@de .

<https://example.org/eli/de/be/bauo/2005/par_50/abs_1/nr_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
    eli:number "2" ;
