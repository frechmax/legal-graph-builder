<https://example.org/eli/de/be/bauo/2005/par_65a/abs_1> eli:has_part <https://example.org/eli/de/be/bauo/2005/par_65a/abs_1/nr_1> .

<https://example.org/eli/de/be/bauo/2005/par_65a/abs_1/nr_1> eli:description "einen berufsqualifizierenden Hochschulabschluss eines Studiums der Fachrichtung Bauingenieurwesen gemäß den in der Anlage geregelten Leitlinien an einer deutschen Hochschule nachweist und"@de .

<https://example.org/eli/de/be/bauo/2005/par_65a/abs_1/nr_2> a eli:LegalResourceSubdivision ;
    eli:type_subdivision exvocab:nummer ;
